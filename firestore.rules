rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    match /apps/{appId} {
      // General rule for all collections inside an app to simplify management
      // while maintaining basic auth security
      match /{collectionName}/{docId} {
        allow read, write: if isSignedIn();
      }
      
      // Specifically allow sub-collections if any (none currently used in App.jsx but good for future)
      match /{path=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
